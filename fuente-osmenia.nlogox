<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="false">
  <code><![CDATA[globals [
  park-radius
  outer-ring-radius
  outer-ring-width
  inner-plaza-outer-radius
  inner-plaza-inner-radius
  fountain-radius
  path-angle-deg
  path-width
  entrance-ne
  entrance-sw
  total-litter-events
  total-litter-on-ground
  time-to-first-litter
  first-litter-recorded
  total-agents-spawned

  ;; Precomputed checkpoint lists (lists of patches, in angular order)
  outer-ring-checkpoints
  inner-plaza-checkpoints
]

patches-own [
  zone
  litter-count
  norm-signal
  litter-attractiveness
]

breed [people person]
breed [bins bin]

people-own [
  agent-type
  has-trash
  trash-items-remaining
  holding-fatigue
  fatigue-threshold
  hedonic-weight
  normative-weight
  norm-signal-personal
  vision-range
  effort-tolerance
  social-influence-weight
  environmental-sensitivity
  dwell-time
  jog-distance-budget    ;; total distance jogger will run before switching to walk-exit
  jog-distance-traveled  ;; accumulated distance covered while jogging
  speed
  exited
  jog-walk-speed
  destination
  checkpoint-index
  use-inner-circuit
  jog-direction
]

bins-own [
  capacity
  current-load
  bin-type
]

to setup
  clear-all

  set park-radius               35
  set outer-ring-radius         30
  set outer-ring-width           2
  set inner-plaza-outer-radius  12
  set inner-plaza-inner-radius   8
  set fountain-radius            3
  set path-angle-deg            50
  set path-width                 2

  set total-litter-events       0
  set total-litter-on-ground    0
  set time-to-first-litter     -1
  set first-litter-recorded    false
  set total-agents-spawned      0

  setup-patches
  setup-entrances
  setup-checkpoints
  setup-initial-litter
  setup-bins
  ;; No agents at t=0; they arrive over time via spawn-arrivals in go

  reset-ticks
end

;;; ============================================================
;;; PATCH SETUP
;;; ============================================================

to setup-patches
  ask patches [
    let d distance patch 0 0
    let angle-rad (path-angle-deg * pi / 180)
    let perp-dist abs (pxcor * cos angle-rad - pycor * sin angle-rad)
    let on-path (perp-dist <= path-width)

    ifelse d > park-radius [
      set zone "exterior"
    ] [
    ifelse d <= fountain-radius [
      set zone "fountain"
    ] [
    ifelse d <= inner-plaza-outer-radius [
      set zone "inner-plaza"
    ] [
    ifelse on-path [
      set zone "path"
    ] [
    ifelse (d >= (outer-ring-radius - outer-ring-width) and
            d <= (outer-ring-radius + outer-ring-width)) [
      set zone "outer-ring"
    ] [
      set zone "grass"
    ]]]]]

    if zone = "grass"       [ set litter-attractiveness 1.0  ]
    if zone = "inner-plaza" [ set litter-attractiveness 0.2  ]
    if zone = "outer-ring"  [ set litter-attractiveness 0.3  ]
    if zone = "path"        [ set litter-attractiveness 0.3  ]
    if zone = "entrance"    [ set litter-attractiveness 0.2  ]
    if zone = "fountain"    [ set litter-attractiveness 0.2  ]
    if zone = "exterior"    [ set litter-attractiveness 0.2  ]

    set litter-count 0
    set norm-signal 1.0
    color-patch
  ]
end

to color-patch
  if zone = "exterior"    [ set pcolor 29  ]
  if zone = "grass"       [ set pcolor 64  ]
  if zone = "outer-ring"  [ set pcolor 8   ]
  if zone = "path"        [ set pcolor 8   ]
  if zone = "inner-plaza" [ set pcolor 7   ]
  if zone = "fountain"    [ set pcolor 97  ]
  if zone = "entrance"    [ set pcolor 45  ]
end

;;; ============================================================
;;; CHECKPOINTS
;;; ============================================================

to setup-checkpoints
  ;; 16 checkpoints gives ~22.5 degree spacing — smoother circuit,
  ;; less likely to cut across zones between waypoints
  set outer-ring-checkpoints build-checkpoints "outer-ring" outer-ring-radius 16
  set inner-plaza-checkpoints build-checkpoints "inner-plaza" (fountain-radius + 5) 16
end

to-report build-checkpoints [target-zone target-radius n-points]
  let result []
  let i 0
  while [i < n-points] [
    let angle (i * 360 / n-points)
    let cx target-radius * sin (angle)
    let cy target-radius * cos (angle)
    let best min-one-of patches with [ zone = target-zone ] [
      distancexy cx cy
    ]
    if best != nobody [
      set result lput best result
    ]
    set i i + 1
  ]
  report result
end

;;; ============================================================
;;; ENTRANCES
;;; ============================================================

to setup-entrances
  let angle-rad (path-angle-deg * pi / 180)
  let ne-x round ((park-radius - 1) * sin angle-rad)
  let ne-y round ((park-radius - 1) * cos angle-rad)
  let sw-x (0 - ne-x)
  let sw-y (0 - ne-y)

  ask patches with [
    distance patch ne-x ne-y <= 2 and zone != "exterior"
  ] [
    set zone "entrance"
    set litter-attractiveness 0.2
    color-patch
  ]
  ask patches with [
    distance patch sw-x sw-y <= 2 and zone != "exterior"
  ] [
    set zone "entrance"
    set litter-attractiveness 0.2
    color-patch
  ]

  set entrance-ne patch ne-x ne-y
  set entrance-sw patch sw-x sw-y
end

;;; ============================================================
;;; INITIAL LITTER SEEDING
;;; ============================================================

to setup-initial-litter
  if initial-litter > 0 [
    ask patches with [
      zone = "grass" or zone = "inner-plaza" or
      zone = "outer-ring" or zone = "path"
    ] [
      if random-float 1.0 < (initial-litter * 0.003) [
        set litter-count (1 + random initial-litter)
        set norm-signal max (list 0.0 (1.0 - litter-count * 0.15))
        recolor-litter-patch
      ]
    ]
    set total-litter-on-ground sum [litter-count] of patches
  ]
end

;;; ============================================================
;;; BINS
;;; ============================================================

to setup-bins
  place-bins-at-entrance entrance-ne
  place-bins-at-entrance entrance-sw

  if bin-placement >= 2 [ place-bins-on-outer-ring ]
  if bin-placement >= 3 [ place-bins-on-inner-plaza ]
end

to place-bins-at-entrance [ep]
  let candidates patches with [
    distance ep <= 4 and
    (zone = "outer-ring" or zone = "path" or
     zone = "entrance" or zone = "grass")
  ]
  if not any? candidates [ stop ]

  let spots up-to-n-of 2 candidates
  ask spots [
    sprout-bins 1 [
      set bin-type "large"
      set capacity 50
      set current-load 0
      set color 62
      set shape "circle"
      set size 1.3
    ]
  ]
  ask one-of candidates [
    sprout-bins 1 [
      set bin-type "drum"
      set capacity 20
      set current-load 0
      set color 105
      set shape "circle"
      set size 1.0
    ]
  ]
end

to place-bins-on-outer-ring
  let ring-patches patches with [
    zone = "outer-ring" and
    distance entrance-ne > 5 and
    distance entrance-sw > 5
  ]
  if any? ring-patches [
    ask up-to-n-of 4 ring-patches [
      sprout-bins 1 [
        set bin-type "large"
        set capacity 50
        set current-load 0
        set color 62
        set shape "circle"
        set size 1.3
      ]
    ]
  ]
end

to place-bins-on-inner-plaza
  let plaza-patches patches with [
    zone = "inner-plaza" and
    distance patch 0 0 > (fountain-radius + 3) and
    distance patch 0 0 < (inner-plaza-outer-radius - 1)
  ]
  if any? plaza-patches [
    ask up-to-n-of 4 plaza-patches [
      sprout-bins 1 [
        set bin-type "large"
        set capacity 50
        set current-load 0
        set color 62
        set shape "circle"
        set size 1.3
      ]
    ]
  ]
end

;;; ============================================================
;;; ARRIVAL SPAWNER
;;; Called each tick. Uses a Poisson process: each tick,
;;; spawn an agent with probability (arrival-rate / 10).
;;; This gives an average of arrival-rate agents per 10 ticks,
;;; but arrival times are staggered and random.
;;;
;;; Entrance assignment is asymmetric and re-drawn each spawn:
;;; NE gets a random weight between 30% and 70%, so over time
;;; neither entrance dominates consistently.
;;;
;;; Agent type: 60% jogger, 40% leisurer, drawn independently.
;;; ============================================================

to spawn-arrivals
  ;; Poisson tick probability: lambda = arrival-rate / 10
  let spawn-prob arrival-rate / 40.0
  ;; Allow at most 3 arrivals per tick to avoid pile-ups at high rates
  let arrivals-this-tick 0
  while [arrivals-this-tick < 3 and random-float 1.0 < spawn-prob] [
    ;; Re-draw entrance bias each spawn — asymmetric, not fixed 50/50
    let ne-weight 0.30 + random-float 0.40   ;; uniform in [0.30, 0.70]
    let spawn-entrance ifelse-value (random-float 1.0 < ne-weight)
      [ entrance-ne ]
      [ entrance-sw ]

    ifelse random-float 1.0 < jogger-to-leisurers-ratio [
      spawn-one-jogger spawn-entrance
    ] [
      spawn-one-leisurer spawn-entrance
    ]

    set total-agents-spawned total-agents-spawned + 1
    set arrivals-this-tick arrivals-this-tick + 1
    ;; Reduce effective probability for subsequent agents this tick
    ;; so rate doesn't compound — each extra agent is increasingly unlikely
    set spawn-prob spawn-prob * 0.4
  ]
end

;;; ============================================================
;;; SINGLE-AGENT SPAWNERS
;;; ============================================================

to spawn-one-jogger [ep]
  create-people 1 [
    set agent-type "jogger"
    set shape "person"
    set color sky
    set size 1.2
    set speed 2.2
    set jog-walk-speed 0.6
    set vision-range 5
    set effort-tolerance 4
    set social-influence-weight 0.3
    set environmental-sensitivity 0.4
    set jog-distance-budget 100 + random-float 300
    set jog-distance-traveled 0
    set dwell-time -1
    set destination nobody
    set exited false
    set use-inner-circuit (random-float 1.0 < 0.30)
    set jog-direction 1        ;; default; set properly below outside create block
    set checkpoint-index 0
    assign-gft-weights
    set trash-items-remaining (random 2)
    assign-trash "jogger"
    move-to ep
  ]
  ;; Set direction and nearest checkpoint outside create block to avoid scoping issues
  ask people with [ agent-type = "jogger" and destination = nobody ] [
    ;; 80% counterclockwise, 20% clockwise
    set jog-direction ifelse-value (random-float 1.0 < 0.80) [ 1 ] [ -1 ]
    let circuit ifelse-value use-inner-circuit
      [ inner-plaza-checkpoints ]
      [ outer-ring-checkpoints ]
    if length circuit > 0 [
      let nearest-idx 0
      let nearest-dist 9999
      let ep-x [pxcor] of ep
      let ep-y [pycor] of ep
      let ci 0
      while [ci < length circuit] [
        let chk item ci circuit
        let d ([distancexy ep-x ep-y] of chk)
        if d < nearest-dist [
          set nearest-dist d
          set nearest-idx ci
        ]
        set ci ci + 1
      ]
      if jog-direction = -1 [
        set nearest-idx (nearest-idx + length circuit - 1) mod (length circuit)
      ]
      set checkpoint-index nearest-idx
      set destination item checkpoint-index circuit
    ]
  ]
end

to spawn-one-leisurer [ep]
  create-people 1 [
    set agent-type "leisurer"
    set shape "person"
    set color pink
    set size 1.2
    set speed 0.8
    set jog-walk-speed 0.8
    set vision-range 4
    set effort-tolerance 4
    set social-influence-weight 0.5
    set environmental-sensitivity 0.6
    set dwell-time -1
    set jog-distance-budget 0
    set jog-distance-traveled 0
    set destination nobody
    set exited false
    assign-gft-weights
    set trash-items-remaining (random 2)   ;; 3–5 items; was 1–2
    assign-trash "leisurer"
    move-to ep
    set destination leisurer-initial-destination
  ]
end

;;; ============================================================
;;; GFT WEIGHTS
;;; ============================================================

to assign-gft-weights
  let u1 random-float 1.0
  let u2 random-float 1.0
  set hedonic-weight (min (list u1 u2)) * 0.8 + 0.05
  let noise ((random-float 0.2) - 0.1)
  set normative-weight max (list 0.1 (1.0 - hedonic-weight + noise))
  set norm-signal-personal 1.0
  set holding-fatigue 0.0
  set fatigue-threshold (0.5 + random-float 1.0)   ;; 0.5–1.5, was 1.0–3.0
end

to assign-trash [atype]
  ;; All agents start carrying trash — prob controls WHETHER they have it now
  ;; vs it being still in their bag to consume later
  let prob 0.70
  if atype = "jogger"   [ set prob 0.60 ]
  if atype = "leisurer" [ set prob 0.85 ]
  set has-trash (random-float 1.0 < prob)
  if has-trash and trash-items-remaining > 0 [
    set trash-items-remaining trash-items-remaining - 1
  ]
  ;; Do not override to false if remaining > 0 — they still have items to consume
  if trash-items-remaining <= 0 [ set has-trash false ]
end

;;; ============================================================
;;; TRASH REGENERATION (LIMITED)
;;; ============================================================

to maybe-pickup-next-trash
  if not has-trash and trash-items-remaining > 0 [
    let pickup-prob 0.0
    if agent-type = "leisurer" [ set pickup-prob 0.008 ]  ;; ~every 125 ticks, was 500
    if agent-type = "jogger"   [ set pickup-prob 0.005 ]  ;; ~every 200 ticks, was 1000

    if random-float 1.0 < pickup-prob [
      set has-trash true
      set holding-fatigue 0
      set trash-items-remaining trash-items-remaining - 1
    ]
  ]
end

;;; ============================================================
;;; DESTINATION HELPERS
;;; ============================================================

to-report jogger-checkpoint-patch [idx]
  let circuit ifelse-value use-inner-circuit
    [ inner-plaza-checkpoints ]
    [ outer-ring-checkpoints ]
  if length circuit = 0 [ report one-of (list entrance-ne entrance-sw) ]
  let n length circuit
  ;; mod in NetLogo can return negative for negative idx, so normalize
  report item ((idx mod n + n) mod n) circuit
end

to-report leisurer-plaza-destination
  let candidates patches with [
    zone = "inner-plaza" and
    distance patch 0 0 > (fountain-radius + 3) and
    distance patch 0 0 < (inner-plaza-outer-radius - 1)
  ]
  if not any? candidates [ report patch 0 0 ]
  report one-of candidates
end

to-report leisurer-initial-destination
  ;; 60% head to inner plaza, 25% outer ring, 15% grass
  let roll random-float 1.0
  ifelse roll < 0.60 [
    report leisurer-plaza-destination
  ] [
  ifelse roll < 0.85 [
    let candidates patches with [ zone = "outer-ring" ]
    if any? candidates [ report one-of candidates ]
    report leisurer-plaza-destination  ;; fallback
  ] [
    let candidates patches with [ zone = "grass" ]
    if any? candidates [ report one-of candidates ]
    report leisurer-plaza-destination  ;; fallback
  ]]
end

;;; ============================================================
;;; MAIN LOOP
;;; ============================================================

to go
  if limit-ticks and ticks >= 1000 [ stop ]

  spawn-arrivals

  ask people with [ not exited ] [
    escape-if-stuck
    move-agent
    maybe-pickup-next-trash
    if has-trash [ update-fatigue ]
    observe-environment
    if has-trash [ decide-litter ]
    check-exit
    update-trash-color
  ]

  update-patch-norm-signals
  scatter-litter
  update-metrics
  tick
end

;;; ============================================================
;;; ESCAPE
;;; ============================================================

to escape-if-stuck
  if [zone] of patch-here = "fountain" or
     [zone] of patch-here = "exterior" [
    let safe-patch min-one-of patches with [
      zone = "inner-plaza" and
      distance patch 0 0 > (fountain-radius + 1)
    ] [distance self]
    if safe-patch != nobody [ move-to safe-patch ]
  ]
end

;;; ============================================================
;;; MOVEMENT
;;; ============================================================

to move-agent
  if agent-type = "leisurer" and dwell-time > 0 [
    if random-float 1.0 < 0.25 [
      ;; 60% stay near inner-plaza, 40% wander out to grass
      ;; Use a large radius so grass is actually reachable from the plaza center
      ifelse random-float 1.0 < 0.60 [
        let wander-target one-of patches in-radius 6 with [
          zone = "inner-plaza" and
          distance patch 0 0 > (fountain-radius + 2)
        ]
        if wander-target != nobody [
          face wander-target
          fd min (list 0.5 (distance wander-target))
        ]
      ] [
        ;; Grass wander: pick any grass patch within radius 15
        ;; (grass starts just outside inner-plaza at radius ~12)
        let wander-target one-of patches in-radius 15 with [ zone = "grass" ]
        if wander-target != nobody [
          face wander-target
          fd min (list 0.6 (distance wander-target))
        ]
      ]
    ]
    stop
  ]

  if destination = nobody [ set destination find-destination ]
  if destination = nobody [ stop ]
  if not is-traversable destination [ set destination find-destination ]
  if destination = nobody [ stop ]

  face destination

  let next-p patch-ahead 1
  ifelse next-p != nobody and is-traversable next-p [
    ;; Clamp step to 1.0 so agents never skip over zone boundaries in one tick
    let step min (list 1.0 (distance destination))
    fd step
  ] [
    ;; Blocked: steer toward the nearest traversable patch rather than a random
    ;; neighbor — random neighbor causes entrance oscillation
    let dest-x [pxcor] of destination
    let dest-y [pycor] of destination
    let best-alt min-one-of (neighbors with [
      zone != "exterior" and zone != "fountain"
    ]) [ distancexy dest-x dest-y ]
    if best-alt != nobody [ face best-alt fd 0.5 ]
  ]

  if [zone] of patch-here = "fountain" or
     [zone] of patch-here = "exterior" [
    ;; Teleport to nearest traversable patch on the path or outer ring
    ;; (not inner-plaza) so the agent stays near where it entered
    let safe-patch min-one-of patches with [
      (zone = "path" or zone = "outer-ring" or zone = "grass") and
      distance patch 0 0 < (park-radius - 1)
    ] [distance self]
    if safe-patch = nobody [
      set safe-patch min-one-of patches with [
        zone = "inner-plaza" and distance patch 0 0 > (fountain-radius + 1)
      ] [distance self]
    ]
    if safe-patch != nobody [ move-to safe-patch ]
  ]

  if distance destination < 1.5 [
    handle-arrival
  ]
end

;;; ============================================================
;;; ARRIVAL HANDLING
;;; ============================================================

to handle-arrival
  if agent-type = "jogger" and jog-distance-traveled < jog-distance-budget [
    ;; Accumulate distance covered to this checkpoint
    set jog-distance-traveled jog-distance-traveled + (distance destination + 1)
    ;; Advance in the jogger's assigned direction (1=CCW, -1=CW)
    let circuit-len length ifelse-value use-inner-circuit
      [ inner-plaza-checkpoints ] [ outer-ring-checkpoints ]
    set checkpoint-index ((checkpoint-index + jog-direction) mod circuit-len + circuit-len) mod circuit-len
    ifelse jog-distance-traveled < jog-distance-budget [
      set destination jogger-checkpoint-patch checkpoint-index
    ] [
      ;; Budget exhausted: transition smoothly to walk-to-exit
      set speed jog-walk-speed
      set destination one-of (list entrance-ne entrance-sw)
    ]
  ]

  if agent-type = "leisurer" and dwell-time = -1 [
    if [zone] of patch-here = "inner-plaza" [
      set dwell-time (60 + random 120)
      set destination nobody
    ]
    ;; For outer-ring/grass: shorter dwell, no re-roam eligibility resets
    if [zone] of patch-here = "outer-ring" or [zone] of patch-here = "grass" [
      set dwell-time (20 + random 40)
      set destination nobody
    ]
  ]
end

to-report is-traversable [p]
  if p = nobody [ report false ]
  let z [zone] of p
  report (z != "exterior" and z != "fountain")
end

to-report find-traversable-neighbor
  let candidates neighbors with [
    zone != "exterior" and zone != "fountain"
  ]
  if any? candidates [ report one-of candidates ]
  report nobody
end

to-report find-destination
  if agent-type = "jogger" [
    ifelse jog-distance-traveled < jog-distance-budget [
      report jogger-checkpoint-patch checkpoint-index
    ] [
      report one-of (list entrance-ne entrance-sw)
    ]
  ]
  if agent-type = "leisurer" [
    if dwell-time = -1 [ report leisurer-plaza-destination ]
    if dwell-time > 0  [ report nobody ]
    if dwell-time = 0  [
      ;; 40% chance to wander again rather than exit immediately
      ifelse random-float 1.0 < 0.40 [
        set dwell-time -1   ;; reset so they can dwell again if they reach plaza
        report leisurer-initial-destination
      ] [
        report one-of (list entrance-ne entrance-sw)
      ]
    ]
  ]
  report patch 0 0
end

;;; ============================================================
;;; TRASH VISUAL INDICATOR
;;; Jogger base: sky. Leisurer base: pink.
;;; Carrying trash: red. Post-jog walk phase: white.
;;; ============================================================

to update-trash-color
  ifelse has-trash [
    set color red
  ] [
    ifelse agent-type = "jogger" [
      ifelse jog-distance-traveled >= jog-distance-budget [
        set color white
      ] [
        set color sky
      ]
    ] [
      set color pink
    ]
  ]
end

;;; ============================================================
;;; FATIGUE
;;; ============================================================

to update-fatigue
  ;; Increased from 0.02 to 0.05 so fatigue reaches threshold in ~20-60 ticks
  ;; rather than 50-150 ticks. fatigue-threshold is now also lower (see assign-gft-weights).
  set holding-fatigue holding-fatigue + 0.05
end

;;; ============================================================
;;; ENVIRONMENT OBSERVATION
;;; ============================================================

to observe-environment
  let local-litter sum [litter-count] of patches in-radius vision-range

  if local-litter > 0 [
    let litter-effect environmental-sensitivity *
      (local-litter / (vision-range ^ 2)) * 0.1
    set norm-signal-personal max (list 0.0
      (norm-signal-personal - litter-effect))
  ]

  set norm-signal-personal min (list 1.0 (norm-signal-personal + 0.005))
end

;;; ============================================================
;;; LITTERING DECISION (GFT)
;;; ============================================================

to decide-litter
  ;; Leisurers walking to plaza haven't settled yet — no littering en route
  if agent-type = "leisurer" and dwell-time = -1 [ stop ]

  let nearby-bins bins in-radius effort-tolerance
  if any? nearby-bins [
    let target-bin min-one-of nearby-bins [distance self]
    if not (agent-type = "leisurer" and dwell-time > 0) [
      face target-bin
      fd min (list speed (distance target-bin))
      if [zone] of patch-here = "fountain" or
         [zone] of patch-here = "exterior" [
        let safe-patch min-one-of patches with [
          zone = "inner-plaza" and distance patch 0 0 > (fountain-radius + 1)
        ] [distance self]
        if safe-patch != nobody [ move-to safe-patch ]
      ]
    ]
    if distance target-bin < 1.5 [
      ask target-bin [ set current-load current-load + 1 ]
      set has-trash false
      set holding-fatigue 0
    ]
    stop
  ]

  let hedonic-payoff hedonic-weight * holding-fatigue
  let normative-payoff normative-weight * norm-signal-personal

  if hedonic-payoff > normative-payoff [
    let base-prob min (list 1.0
      ((hedonic-payoff - normative-payoff) / fatigue-threshold))
    let litter-prob base-prob * [litter-attractiveness] of patch-here

    if random-float 1.0 < litter-prob [
      ask patch-here [ set litter-count litter-count + 1 ]
      set has-trash false
      set holding-fatigue 0
      set total-litter-events total-litter-events + 1

      if not first-litter-recorded [
        set time-to-first-litter ticks
        set first-litter-recorded true
      ]

      recolor-litter-patch
    ]
  ]
end

to recolor-litter-patch
  let base-color 0
  if zone = "grass"       [ set base-color 64 ]
  if zone = "outer-ring"  [ set base-color 8  ]
  if zone = "inner-plaza" [ set base-color 7  ]
  if zone = "path"        [ set base-color 8  ]
  if zone = "entrance"    [ set base-color 45 ]
  if litter-count > 0 [
    set pcolor max (list (base-color - min (list litter-count 3)) 1)
  ]
end


to place-bin-mouse
  if mouse-down? [
    let target patch mouse-xcor mouse-ycor
    if [zone] of target != "exterior" and [zone] of target != "fountain" [
      if not any? bins-on target [
        ask target [
          sprout-bins 1 [
            set bin-type "large"
            set capacity 50
            set current-load 0
            set color 62
            set shape "circle"
            set size 1.3
          ]
        ]
      ]
    ]
  ]
end

to remove-bin-mouse
  if mouse-down? [
    let target patch mouse-xcor mouse-ycor
    if any? bins-on target [
      ask bins-on target [ die ]
    ]
  ]
end

;;; ============================================================
;;; EXIT CHECK
;;; ============================================================

to check-exit
  if agent-type = "jogger" [
    if jog-distance-traveled >= jog-distance-budget [
      if distance entrance-ne < 1 or distance entrance-sw < 1 [
        set exited true
        die
      ]
    ]
  ]

  if agent-type = "leisurer" [
    if dwell-time > 0 [
      set dwell-time dwell-time - 1
      if dwell-time = 0 [
        ;; 40% re-roam once, then exit. -2 means "used re-roam, now exit"
        ifelse random-float 1.0 < 0.40 [
          set dwell-time -1
          set destination leisurer-initial-destination
        ] [
          set destination one-of (list entrance-ne entrance-sw)
        ]
      ]
    ]
    if dwell-time = 0 [
      if distance entrance-ne < 1 or distance entrance-sw < 1 [
        set exited true
        die
      ]
    ]
  ]
end

;;; ============================================================
;;; PATCH NORM SIGNAL UPDATE
;;; ============================================================

to update-patch-norm-signals
  ask patches with [ zone != "exterior" and zone != "fountain" ] [
    if litter-count > 0 [
      set norm-signal max (list 0.0
        (norm-signal - (litter-count * 0.001)))
    ]
    set norm-signal min (list 1.0 (norm-signal + 0.002))
  ]
end

;;; ============================================================
;;; LITTER SCATTER
;;; When a patch accumulates >= litter-scatter-threshold pieces,
;;; it offloads 1 piece to a random eligible neighbor each tick.
;;; Models wind, foot traffic, and physical spread of litter.
;;; Only scatters to traversable non-exterior non-fountain patches.
;;; ============================================================

to scatter-litter
  ask patches with [
    litter-count >= litter-scatter-threshold and
    zone != "exterior" and zone != "fountain"
  ] [
    let targets neighbors with [
      zone != "exterior" and zone != "fountain"
    ]
    if any? targets [
      let dest one-of targets
      set litter-count litter-count - 1
      ask dest [
        set litter-count litter-count + 1
        recolor-litter-patch
      ]
      recolor-litter-patch
    ]
  ]
end

;;; ============================================================
;;; METRICS
;;; ============================================================

to update-metrics
  set total-litter-on-ground sum [litter-count] of patches
end

to-report bin-utilization-rate
  let total-capacity sum [capacity] of bins
  if total-capacity = 0 [ report 0 ]
  report (sum [current-load] of bins) / total-capacity
end

to-report litter-hotspot-count
  report count patches with [ litter-count >= 3 ]
end]]></code>
